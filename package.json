{
  "name": "scoremoro",
  "private": true,
  "version": "0.1.0",
  "description": "A focused pomodoro timer for Windows and macOS",
  "author": "Scoremoro",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite build && electron .",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest",
    "electron": "electron .",
    "dist": "tsc -b && vite build && electron-builder",
    "dist:win": "tsc -b && vite build && electron-builder --win",
    "dist:mac": "tsc -b && vite build && electron-builder --mac",
    "dist:all": "tsc -b && vite build && electron-builder --win --mac"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  },
  "build": {
    "appId": "com.scoremoro.timer",
    "productName": "Scoremoro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "portable"
    },
    "mac": {
      "icon": "build/icon.ico",
      "target": "dmg",
      "category": "public.app-category.productivity",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
